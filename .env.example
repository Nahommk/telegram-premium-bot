# ---- Telegram ----
# From @BotFather. Either BOT_TOKEN or TELEGRAM_BOT_TOKEN works.
BOT_TOKEN=123456:ABC-your-bot-token
# Any random string. Telegram echoes this header on every webhook hit.
TELEGRAM_WEBHOOK_SECRET=change-me-to-a-long-random-string
# Comma-separated numeric Telegram user IDs (get yours from @userinfobot)
ADMIN_TELEGRAM_IDS=123456789,987654321

# ---- Supabase (service role — NEVER expose to client) ----
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service-role-key

# ---- Leul Verify (payment verification) ----
LEUL_VERIFY_API_KEY=your-leul-verify-key

# ---- Runtime ----
# Railway sets PORT automatically; only set locally.
PORT=3000
# webhook (default, for Railway) or polling (for local dev)
BOT_MODE=webhook
